# Dependencies (installed via npm install)
node_modules/

# Version control
.git/
.gitignore
.gitkeep

# Build outputs and cache
dist/
build/
.turbo/
.turbo/
*.tsbuildinfo

# Test files and coverage
test/
tests/
__tests__/
*.test.ts
*.spec.ts
coverage/
.nyc_output/

# Development files
.devcontainer/
.vscode/
.idea/

# Documentation source (README.md is still included)
*.md
!README.md

# Logs and debugging
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
bun-debug.log*

# Environment files
.env
.env.local
.env.*.local

# OS files
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.temp
*.swp
*.swo
*~

# CI/CD configs (package-level, not needed in published package)
.github/
.gitlab-ci.yml
.travis.yml
Jenkinsfile
azure-pipelines.yml

# Turborepo config (local development)
turbo.json

# Root level config files that are for development only
tsconfig.base.json

# kilocode specific
.kilocode/

# Lock files (use bun.lock in package, not needed in npm package)
bun.lock
bun.lockb
yarn.lock
package-lock.json
pnpm-lock.yaml

# Test directories in packages
apps/*/test/
packages/*/test/
templates/*/test/

# Dashboard app (typically deployed separately)
apps/dashboard/

# Individual package README duplicates (use root README)
packages/*/README.md
templates/*/README.md
