{
  "name": "@betterbase/client",
  "version": "0.1.0",
  "description": "TypeScript client for BetterBase backends",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "bun run src/build.ts",
    "dev": "bun run src/build.ts --watch",
    "test": "bun test",
    "typecheck": "tsc --project tsconfig.test.json"
  },
  "keywords": [
    "betterbase",
    "baas",
    "backend",
    "database",
    "realtime"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "typescript": "^5.9.3"
  }
}
